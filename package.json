{
  "name": "nearbytes",
  "version": "1.0.0",
  "description": "Full-stack restaurant discovery app with Convex cloud backend and local SQLite fallback",
  "main": "server/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/index.js",
    "dev": "node scripts/dev.js",
    "dev:static": "node scripts/dev-static.js",
    "build": "node scripts/build-static.js",
    "seed": "node server/seed.js",
    "convex:dev": "npx convex dev --typecheck disable",
    "convex:deploy": "npx convex deploy"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "convex": "^1.34.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  }
}
