{
  "name": "restaurant-nearby-prototype",
  "version": "1.0.0",
  "description": "Location-based restaurant discovery prototype with a Convex backend",
  "main": "scripts/dev-static.js",
  "type": "commonjs",
  "engines": {
    "node": "^20 || ^22"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:static": "node scripts/dev-static.js",
    "convex:dev": "npx convex dev --typecheck disable",
    "convex:codegen": "npx convex codegen",
    "convex:seed-demo": "npx convex run restaurants:ensureFallbackRestaurants",
    "test": "node -e \"console.log('No automated tests configured yet.')\""
  },
  "dependencies": {
    "convex": "^1.34.1",
    "dotenv": "^16.4.7"
  }
}
