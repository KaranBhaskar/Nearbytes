# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
JWT_SECRET=dev-secret-change-me

# ── Convex (optional — leave blank for local SQLite fallback) ─────────────────
# Get these from https://dashboard.convex.dev after running `npx convex dev`
CONVEX_DEPLOYMENT=
CONVEX_URL=

# ── Google Maps (optional — leave blank to use OpenStreetMap/Leaflet) ─────────
# Create a key at https://developers.google.com/maps and enable:
#   - Maps JavaScript API  (browser map tiles)
#   - Places API (New)     (nearby restaurant discovery)
#   - Geocoding API        (address → coordinates)
GOOGLE_MAPS_API_KEY=

# ── Gemini AI (optional — leave blank to skip AI tag enrichment) ──────────────
# Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Nearby search settings ────────────────────────────────────────────────────
OSM_NEARBY_RADIUS_METERS=5000

# ── Deployment (set this to your Vercel/production URL in production) ─────────
CLIENT_ORIGIN=http://localhost:3000
